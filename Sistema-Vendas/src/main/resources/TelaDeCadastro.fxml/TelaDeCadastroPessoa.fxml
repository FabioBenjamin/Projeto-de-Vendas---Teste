<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.SistemaVendas.Controller.ClienteController">

    <children>

        <HBox layoutX="389.0" layoutY="302.0" spacing="10.0">
            <children>
                <Button fx:id="bntIncluir" text="Incluir" onAction="#atualizar"/>
                <Button fx:id="btnDeletar" text="Deletar" onAction="#excluir"/>
                <Button fx:id="btnEditar" text="Editar" onAction="editar"/>
                <Button fx:id="btnFechar" text="Fechar" onAction="fechar"/>
            </children>
            <padding>
                <Insets left="10.0" right="10.0" top="10.0"/>
            </padding>
        </HBox>

        <VBox layoutX="356.0" layoutY="77.0" prefWidth="331.0">
            <children>
                <Label text="ID"/>
                <TextField fx:id="tfID"/>

                <Label text="Nome Completo"/>
                <TextField fx:id="tfNome"/>

                <Label text="Data de Nascimento"/>
                <DatePicker fx:id="DtNascimento"/>

                <Label text="Sexo"/>
                <ComboBox fx:id="cbSexo" prefWidth="150.0"/>
            </children>
            <padding>
                <Insets left="10.0" right="10.0"/>
            </padding>
        </VBox>

        <!-- TABLE CORRIGIDA -->
        <TableView fx:id="tblCliente" layoutX="30.0" layoutY="64.0"
                   prefHeight="351.0" prefWidth="302.0">

            <columns>
                <TableColumn text="ID" prefWidth="75.0"/>
                <TableColumn text="Nome" prefWidth="75.0"/>
                <TableColumn text="Nascimento" prefWidth="75.0"/>
                <TableColumn text="Sexo" prefWidth="75.0"/>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <Label layoutX="73.0" layoutY="14.0" text="Cadastro de Cliente">
            <font>
                <Font size="24.0"/>
            </font>
        </Label>

        <Label layoutX="426.0" layoutY="28.0" text="Dados do Cliente">
            <font>
                <Font size="25.0"/>
            </font>
        </Label>

    </children>
</AnchorPane>